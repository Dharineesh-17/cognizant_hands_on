public class SingletonTest {
    public static void main(String[] args) {

        // Get the single instance twice
        Logger logger1 = Logger.getInstance();
        Logger logger2 = Logger.getInstance();

        // Check if both variables point to the exact same object
        if (logger1==logger2) {
            System.out.println("SUCCESS: logger1 and logger2 are the exact same instance!");
        }

        // Use the instance to print a message
        logger1.log("This is our finalized, easy-to-read Singleton!");
    }
}
 class Logger {

    // 1. Create the single instance right away
    private static Logger instance = new Logger();

    // 2. Make the constructor private so no one can use "new Logger()"
    private Logger() {
    }

    // 3. Provide a way for the program to get the single instance
    public static Logger getInstance() {
        return instance;
    }

    // 4. A simple method to show the logger is working
    public void log(String message) {
        System.out.println("[LOG]: " + message);
    }
}
##For this code the output will be shown as:
SUCCESS: logger1 and logger2 are the exact same instance!
[LOG]: This is our finalized, easy-to-read Singleton!



